# Ignore all data (raw and processed)
data/
!data/**/*.gitkeep

# Ignore model outputs and serving artifacts
model/
model-serving/

# Ignore Python cache and virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
*.sqlite3
*.db
venv/
env/
ENV/
.venv/
.ipynb_checkpoints

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore system files
.DS_Store
Thumbs.db

# Ignore node_modules
node_modules/

# Ignore log files and temporary files
*.log
*.tmp
*.swp

# Ignore large geospatial satellite files
*.nc4
*.hgt
*.zip
*.hdf
*.tif
*.tiff

# Ignore credentials and environment files
.env
.env.*

# Ignore frontend build artifacts
build/
dist/
